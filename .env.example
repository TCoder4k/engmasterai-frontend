# Backend base URL (defaults to http://localhost:3000 if unset)
VITE_API_URL=http://localhost:3000

# No Gemini/AI key is needed here or anywhere else in the frontend — the AI
# demo (components/AIDemo.tsx, services/geminiService.ts) is a permanent,
# deterministic mock that makes no network call and requires no key. Do not
# add a Gemini key variable here — see docs/memory.md's Sprint 01C entry.

# Google Sign-In (Sprint 02A). This is the OAuth Client ID, not a secret —
# it's the public identifier of the app and is safe to bake into the client
# bundle (Google's own docs state this explicitly). Leave empty/unset to
# hide the "Continue with Google" button entirely — the rest of the login
# and register forms work unaffected either way. Must match the backend's
# GOOGLE_CLIENT_ID exactly, and the backend must also have
# GOOGLE_AUTH_ENABLED=true or the button will render but every attempt will
# fail with a "currently unavailable" response.
VITE_GOOGLE_CLIENT_ID=
